# ==============================================================================
# KrishiSetu Monorepo Environment Variables Example
# ==============================================================================
# Copy this file to '.env' for local development. Never commit real credentials.

# ------------------------------------------------------------------------------
# 💻 Frontend Settings (Next.js)
# ------------------------------------------------------------------------------
# Base URL for the Spring Boot JSON API
NEXT_PUBLIC_API_URL=http://localhost:8080

# App-level HTTPS for Docker/EC2. Leave these defaults for local HTTP.
# For EC2 HTTPS, set:
#   NEXT_PUBLIC_API_URL=https://api.yourdomain.com:8443
#   WEB_START_COMMAND=npm run start:https
#   WEB_PUBLISHED_PORT=443
#   PORT=3443
#   WEB_HEALTHCHECK_URL=https://127.0.0.1:3443/
#   CORS_ORIGINS=https://yourdomain.com
WEB_START_COMMAND=npm run start
WEB_PUBLISHED_PORT=3000
PORT=3000
HTTPS_PORT=
HTTPS_HOST=0.0.0.0
HTTPS_KEY_PATH=/certs/web/privkey.pem
HTTPS_CERT_PATH=/certs/web/fullchain.pem
HTTPS_CA_PATH=
WEB_TLS_CERT_DIR=./certs/web
WEB_HEALTHCHECK_URL=http://127.0.0.1:3000/

# Optional: make the browser call the frontend origin and let Next.js proxy API calls.
# Useful for local self-signed HTTPS where browsers may reject the backend cert directly.
# Set NEXT_PUBLIC_API_URL=/ when enabling this proxy mode.
API_PROXY_TARGET=
API_PROXY_TLS_REJECT_UNAUTHORIZED=true

# Supabase configuration for anonymous users (Client-side upload & authentication)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-placeholder

# Supabase Service Role Key (Server-side administration only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-placeholder

# Sentry DSN for frontend telemetry (optional)
NEXT_PUBLIC_SENTRY_DSN=

# ------------------------------------------------------------------------------
# ☕ Backend Settings (Spring Boot)
# ------------------------------------------------------------------------------
# Port the backend runs on locally
SERVER_PORT=8080

# App-level HTTPS for Spring Boot. Leave disabled for local HTTP.
# For EC2 HTTPS, set:
#   SERVER_SSL_ENABLED=true
#   SERVER_PORT=8443
#   API_PUBLISHED_PORT=8443
#   API_HEALTHCHECK_URL=https://127.0.0.1:8443/health
API_PUBLISHED_PORT=8080
SERVER_SSL_ENABLED=false
SERVER_SSL_KEY_STORE=/certs/api/keystore.p12
SERVER_SSL_KEY_STORE_PASSWORD=change-this-keystore-password
SERVER_SSL_KEY_STORE_TYPE=PKCS12
SERVER_SSL_KEY_ALIAS=springboot
API_TLS_KEYSTORE_DIR=./certs/api
API_HEALTHCHECK_URL=http://127.0.0.1:8080/health

# Local Postgres Database configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/krishisetu
DB_USER=krishisetu
DB_PASSWORD=changeme

# Allowed CORS origins (comma-separated, no trailing slash, no wildcards in prod)
CORS_ORIGINS=http://localhost:3000

# Agmarknet Mandi Price API Key (From data.gov.in)
AGMARKNET_API_KEY=your-agmarknet-api-key-placeholder

# Sentry DSN for backend error logging (optional)
SENTRY_DSN=
SENTRY_ENV=local
