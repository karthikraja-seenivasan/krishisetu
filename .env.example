# ==============================================================================
# KrishiSetu Monorepo Environment Variables Example
# ==============================================================================
# Copy this file to '.env' for local development. Never commit real credentials.

# ------------------------------------------------------------------------------
# 💻 Frontend Settings (Next.js)
# ------------------------------------------------------------------------------
# Base URL for the Spring Boot JSON API
NEXT_PUBLIC_API_URL=http://localhost:8080

# Supabase configuration for anonymous users (Client-side upload & authentication)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-placeholder

# Supabase Service Role Key (Server-side administration only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-placeholder

# Sentry DSN for frontend telemetry (optional)
NEXT_PUBLIC_SENTRY_DSN=

# ------------------------------------------------------------------------------
# ☕ Backend Settings (Spring Boot)
# ------------------------------------------------------------------------------
# Port the backend runs on locally
SERVER_PORT=8080

# Local Postgres Database configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/krishisetu
DB_USER=krishisetu
DB_PASSWORD=changeme

# Allowed CORS origins (comma-separated, no trailing slash, no wildcards in prod)
CORS_ORIGINS=http://localhost:3000

# Agmarknet Mandi Price API Key (From data.gov.in)
AGMARKNET_API_KEY=your-agmarknet-api-key-placeholder

# Sentry DSN for backend error logging (optional)
SENTRY_DSN=
SENTRY_ENV=local
